<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <description>Record-triggered flow on Claim. When a claim is created as, or updated to, Status = Approved, the parent Policy Master status is set to "Under Claim Review" so the servicing team knows a payout is pending on that policy. Runs after save; the update is bulkified automatically by the flow engine.</description>
    <environments>Default</environments>
    <interviewLabel>Claim Approved - Update Policy Status {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Claim Approved - Update Policy Status</label>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Update_Parent_Policy</name>
        <label>Update Parent Policy</label>
        <locationX>176</locationX>
        <locationY>287</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Policy__c</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Status__c</field>
            <value>
                <stringValue>Under Claim Review</stringValue>
            </value>
        </inputAssignments>
        <object>Policy_Master__c</object>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Update_Parent_Policy</targetReference>
        </connector>
        <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Approved</stringValue>
            </value>
        </filters>
        <object>Insurance_Claim__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
